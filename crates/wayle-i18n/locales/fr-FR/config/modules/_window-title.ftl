### Configuration Wayle - Module Titre de fenetre

## Configuration du module Titre de fenetre

settings-modules-window-title-format = Format du libellé
    .description = Chaîne de format avec variables : {"{{ title }}"}, {"{{ app }}"}

settings-modules-window-title-icon-name = Icone secours
    .description = Icone quand aucun mappage ne correspond

settings-modules-window-title-icon-mappings = Mappages d'icônes
    .description = Motifs glob vers noms icones (prefixe title: pour correspondance titre)

settings-modules-window-title-border-show = Afficher la bordure
    .description = Afficher une bordure autour du bouton

settings-modules-window-title-border-color = Couleur de bordure
    .description = Valeur de couleur de bordure

settings-modules-window-title-icon-show = Afficher l'icone
    .description = Afficher l'icone du module

settings-modules-window-title-icon-color = Couleur de l'icone
    .description = Couleur de premier plan de l'icone

settings-modules-window-title-icon-bg-color = Arriere-plan de l'icone
    .description = Couleur d'arriere-plan du conteneur d'icone

settings-modules-window-title-label-show = Afficher le libellé
    .description = Afficher le libellé du titre de fenetre

settings-modules-window-title-label-color = Couleur du libellé
    .description = Couleur du texte du libellé

settings-modules-window-title-label-max-length = Longueur max du libellé
    .description = Nombre maximal de caracteres avant troncature (0 pour desactiver)

settings-modules-window-title-button-bg-color = Arriere-plan du bouton
    .description = Couleur d'arriere-plan du bouton

settings-modules-window-title-left-click = Clic gauche
    .description = Commande shell au clic gauche

settings-modules-window-title-right-click = Clic droit
    .description = Commande shell au clic droit

settings-modules-window-title-middle-click = Clic milieu
    .description = Commande shell au clic milieu

settings-modules-window-title-scroll-up = Defilement vers le haut
    .description = Commande shell au defilement vers le haut

settings-modules-window-title-scroll-down = Defilement vers le bas
    .description = Commande shell au defilement vers le bas
