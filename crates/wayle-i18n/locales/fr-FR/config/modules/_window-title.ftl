settings-modules-window-title-middle-click = Clic milieu
    .description = Commande shell au clic milieu

settings-modules-window-title-scroll-up = Défilement vers le haut
    .description = Commande shell au défilement vers le haut

settings-modules-window-title-scroll-down = Défilement vers le bas
    .description = Commande shell au défilement vers le bas
