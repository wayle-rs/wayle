### Configuration Wayle - Module Horloge

## Configuration du module Horloge

settings-modules-clock-format = Format horaire
    .description = Format d'affichage de l'heure avec la syntaxe strftime

settings-modules-clock-icon-name = Nom de l'icone
    .description = Nom icone symbolique

settings-modules-clock-border-show = Afficher la bordure
    .description = Afficher une bordure autour du bouton

settings-modules-clock-border-color = Couleur de bordure
    .description = Valeur de couleur de bordure

settings-modules-clock-icon-show = Afficher l'icone
    .description = Afficher l'icone du module

settings-modules-clock-icon-color = Couleur de l'icone
    .description = Couleur de premier plan de l'icone

settings-modules-clock-icon-bg-color = Arriere-plan de l'icone
    .description = Couleur d'arriere-plan du conteneur d'icone

settings-modules-clock-label-show = Afficher le libellé
    .description = Afficher le libellé texte

settings-modules-clock-label-color = Couleur du libellé
    .description = Couleur du texte du libellé

settings-modules-clock-label-max-length = Longueur max du libellé
    .description = Nombre maximal de caracteres avant troncature

settings-modules-clock-button-bg-color = Arriere-plan du bouton
    .description = Couleur d'arriere-plan du bouton

settings-modules-clock-left-click = Clic gauche
    .description = Commande shell au clic gauche

settings-modules-clock-right-click = Clic droit
    .description = Commande shell au clic droit

settings-modules-clock-middle-click = Clic milieu
    .description = Commande shell au clic milieu

settings-modules-clock-scroll-up = Defilement vers le haut
    .description = Commande shell au defilement vers le haut

settings-modules-clock-scroll-down = Defilement vers le bas
    .description = Commande shell au defilement vers le bas
