### Configuration Wayle - Module Notifications

## Configuration du module Notifications

settings-modules-notification-icon-name = Icône par défaut
    .description = Icône affichée quand il n'y a aucune notification

settings-modules-notification-icon-unread = Icône non lue
    .description = Icône affichée quand des notifications existent

settings-modules-notification-icon-dnd = Icône NPD
    .description = Icône affichée quand le mode Ne pas déranger est actif

settings-modules-notification-border-show = Afficher la bordure
    .description = Afficher une bordure autour du bouton

settings-modules-notification-border-color = Couleur de bordure
    .description = Valeur de couleur de bordure

settings-modules-notification-icon-show = Afficher l'icône
    .description = Afficher l'icône du module

settings-modules-notification-icon-color = Couleur de l'icône
    .description = Couleur de premier plan de l'icône

settings-modules-notification-icon-bg-color = Arrière-plan de l'icône
    .description = Couleur d'arrière-plan du conteneur d'icône

settings-modules-notification-label-show = Afficher le libellé
    .description = Afficher le libellé du nombre de notifications

settings-modules-notification-label-color = Couleur du libellé
    .description = Couleur du texte du libellé

settings-modules-notification-label-max-length = Longueur max du libellé
    .description = Nombre maximal de caractères avant troncature

settings-modules-notification-button-bg-color = Arrière-plan du bouton
    .description = Couleur d'arrière-plan du bouton

settings-modules-notification-middle-click = Clic milieu
    .description = Commande shell au clic milieu

settings-modules-notification-scroll-up = Défilement vers le haut
    .description = Commande shell au défilement vers le haut

settings-modules-notification-scroll-down = Défilement vers le bas
    .description = Commande shell au défilement vers le bas
