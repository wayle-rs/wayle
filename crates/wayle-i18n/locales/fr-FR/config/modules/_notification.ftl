settings-modules-notification-icon-show = Afficher l'icone
    .description = Afficher l'icone du module

settings-modules-notification-icon-color = Couleur de l'icone
    .description = Couleur de premier plan de l'icone

settings-modules-notification-icon-bg-color = Arriere-plan de l'icone
    .description = Couleur d'arriere-plan du conteneur d'icone

settings-modules-notification-label-show = Afficher le libellé
    .description = Afficher le libellé du nombre de notifications

settings-modules-notification-label-color = Couleur du libellé
    .description = Couleur du texte du libellé

settings-modules-notification-label-max-length = Longueur max du libellé
    .description = Nombre maximal de caracteres avant troncature

settings-modules-notification-button-bg-color = Arriere-plan du bouton
    .description = Couleur d'arriere-plan du bouton

settings-modules-notification-middle-click = Clic milieu
    .description = Commande shell au clic milieu

settings-modules-notification-scroll-up = Defilement vers le haut
    .description = Commande shell au defilement vers le haut

settings-modules-notification-scroll-down = Defilement vers le bas
    .description = Commande shell au defilement vers le bas
