### Configuration Wayle - Module RAM

## Configuration du module RAM

settings-modules-ram-poll-interval-ms = Intervalle de sondage
    .description = Intervalle de sondage en millisecondes

settings-modules-ram-format = Format d'affichage
    .description = Chaine de format avec placeholders: {"{{ percent }}"}, {"{{ used_gib }}"}, {"{{ total_gib }}"}, {"{{ available_gib }}"}, {"{{ swap_percent }}"}, {"{{ swap_used_gib }}"}, {"{{ swap_total_gib }}"}

settings-modules-ram-icon-name = Nom de l'icone
    .description = Nom icone symbolique

settings-modules-ram-border-show = Afficher la bordure
    .description = Afficher une bordure autour du bouton

settings-modules-ram-border-color = Couleur de bordure
    .description = Valeur de couleur de bordure

settings-modules-ram-icon-show = Afficher l'icone
    .description = Afficher l'icone du module

settings-modules-ram-icon-color = Couleur de l'icone
    .description = Couleur de premier plan de l'icone

settings-modules-ram-icon-bg-color = Arriere-plan de l'icone
    .description = Couleur d'arriere-plan du conteneur d'icone

settings-modules-ram-label-show = Afficher le libellé
    .description = Afficher le libellé texte

settings-modules-ram-label-color = Couleur du libellé
    .description = Couleur du texte du libellé

settings-modules-ram-label-max-length = Longueur max du libellé
    .description = Nombre maximal de caracteres avant troncature

settings-modules-ram-button-bg-color = Arriere-plan du bouton
    .description = Couleur d'arriere-plan du bouton

settings-modules-ram-left-click = Clic gauche
    .description = Commande shell au clic gauche

settings-modules-ram-right-click = Clic droit
    .description = Commande shell au clic droit

settings-modules-ram-middle-click = Clic milieu
    .description = Commande shell au clic milieu

settings-modules-ram-scroll-up = Defilement vers le haut
    .description = Commande shell au defilement vers le haut

settings-modules-ram-scroll-down = Defilement vers le bas
    .description = Commande shell au defilement vers le bas
