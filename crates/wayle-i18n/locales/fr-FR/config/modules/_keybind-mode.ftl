### Configuration Wayle - Module Mode de raccourcis

## Configuration du module Mode de raccourcis

settings-modules-keybind-mode-format = Format du libellé
    .description = Chaîne de format avec variables : {"{{ mode }}"}

settings-modules-keybind-mode-icon-name = Nom de l'icône
    .description = Nom d'icône symbolique

settings-modules-keybind-mode-auto-hide = Masquage automatique
    .description = Masquer le module quand aucun mode n'est actif

settings-modules-keybind-mode-border-show = Afficher la bordure
    .description = Afficher une bordure autour du bouton

settings-modules-keybind-mode-border-color = Couleur de bordure
    .description = Valeur de couleur de bordure

settings-modules-keybind-mode-icon-show = Afficher l'icone
    .description = Afficher l'icone du module

settings-modules-keybind-mode-icon-color = Couleur de l'icone
    .description = Couleur de premier plan de l'icone

settings-modules-keybind-mode-icon-bg-color = Arriere-plan de l'icone
    .description = Couleur d'arriere-plan du conteneur d'icone

settings-modules-keybind-mode-label-show = Afficher le libellé
    .description = Afficher le libellé de mode

settings-modules-keybind-mode-label-color = Couleur du libellé
    .description = Couleur du texte du libellé

settings-modules-keybind-mode-label-max-length = Longueur max du libellé
    .description = Nombre maximal de caracteres avant troncature (0 pour desactiver)

settings-modules-keybind-mode-button-bg-color = Arriere-plan du bouton
    .description = Couleur d'arriere-plan du bouton

settings-modules-keybind-mode-left-click = Clic gauche
    .description = Commande shell au clic gauche

settings-modules-keybind-mode-right-click = Clic droit
    .description = Commande shell au clic droit

settings-modules-keybind-mode-middle-click = Clic milieu
    .description = Commande shell au clic milieu

settings-modules-keybind-mode-scroll-up = Defilement vers le haut
    .description = Commande shell au defilement vers le haut

settings-modules-keybind-mode-scroll-down = Defilement vers le bas
    .description = Commande shell au defilement vers le bas
