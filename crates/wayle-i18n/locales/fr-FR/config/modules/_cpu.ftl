### Configuration Wayle - Module CPU

## Configuration du module CPU

settings-modules-cpu-poll-interval-ms = Intervalle de sondage
    .description = Intervalle de sondage en millisecondes

settings-modules-cpu-temp-sensor = Capteur de temperature
    .description = Nom du capteur pour la temperature (ex. : "Tctl", "auto")

settings-modules-cpu-format = Format d'affichage
    .description = Chaine de format avec placeholders: {"{{ percent }}"}, {"{{ freq_ghz }}"}, {"{{ avg_freq_ghz }}"}, {"{{ max_freq_ghz }}"}, {"{{ temp_c }}"}, {"{{ temp_f }}"}

settings-modules-cpu-icon-name = Nom de l'icone
    .description = Nom icone symbolique

settings-modules-cpu-border-show = Afficher la bordure
    .description = Afficher une bordure autour du bouton

settings-modules-cpu-border-color = Couleur de bordure
    .description = Valeur de couleur de bordure

settings-modules-cpu-icon-show = Afficher l'icone
    .description = Afficher l'icone du module

settings-modules-cpu-icon-color = Couleur de l'icone
    .description = Couleur de premier plan de l'icone

settings-modules-cpu-icon-bg-color = Arriere-plan de l'icone
    .description = Couleur d'arriere-plan du conteneur d'icone

settings-modules-cpu-label-show = Afficher le libellé
    .description = Afficher le libellé texte

settings-modules-cpu-label-color = Couleur du libellé
    .description = Couleur du texte du libellé

settings-modules-cpu-label-max-length = Longueur max du libellé
    .description = Nombre maximal de caracteres avant troncature

settings-modules-cpu-button-bg-color = Arriere-plan du bouton
    .description = Couleur d'arriere-plan du bouton

settings-modules-cpu-left-click = Clic gauche
    .description = Commande shell au clic gauche

settings-modules-cpu-right-click = Clic droit
    .description = Commande shell au clic droit

settings-modules-cpu-middle-click = Clic milieu
    .description = Commande shell au clic milieu

settings-modules-cpu-scroll-up = Defilement vers le haut
    .description = Commande shell au defilement vers le haut

settings-modules-cpu-scroll-down = Defilement vers le bas
    .description = Commande shell au defilement vers le bas
