### Configuration Wayle - Module Disposition clavier

## Configuration du module Disposition clavier

settings-modules-keyboard-input-format = Format du libellé
    .description = Chaine de format avec placeholders: {"{{ layout }}"}

settings-modules-keyboard-input-icon-name = Nom de l'icone
    .description = Nom icone symbolique

settings-modules-keyboard-input-border-show = Afficher la bordure
    .description = Afficher une bordure autour du bouton

settings-modules-keyboard-input-border-color = Couleur de bordure
    .description = Valeur de couleur de bordure

settings-modules-keyboard-input-icon-show = Afficher l'icone
    .description = Afficher l'icone du module

settings-modules-keyboard-input-icon-color = Couleur de l'icone
    .description = Couleur de premier plan de l'icone

settings-modules-keyboard-input-icon-bg-color = Arriere-plan de l'icone
    .description = Couleur d'arriere-plan du conteneur d'icone

settings-modules-keyboard-input-label-show = Afficher le libellé
    .description = Afficher le libellé de disposition

settings-modules-keyboard-input-label-color = Couleur du libellé
    .description = Couleur du texte du libellé

settings-modules-keyboard-input-label-max-length = Longueur max du libellé
    .description = Nombre maximal de caracteres avant troncature (0 pour desactiver)

settings-modules-keyboard-input-button-bg-color = Arriere-plan du bouton
    .description = Couleur d'arriere-plan du bouton

settings-modules-keyboard-input-left-click = Clic gauche
    .description = Commande shell au clic gauche

settings-modules-keyboard-input-right-click = Clic droit
    .description = Commande shell au clic droit

settings-modules-keyboard-input-middle-click = Clic milieu
    .description = Commande shell au clic milieu

settings-modules-keyboard-input-scroll-up = Defilement vers le haut
    .description = Commande shell au defilement vers le haut

settings-modules-keyboard-input-scroll-down = Defilement vers le bas
    .description = Commande shell au defilement vers le bas
