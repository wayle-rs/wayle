### Configuration Wayle - Module Statistiques reseau

## Configuration du module Statistiques reseau

settings-modules-netstat-poll-interval-ms = Intervalle de sondage
    .description = Intervalle de sondage en millisecondes

settings-modules-netstat-interface = Interface
    .description = Interface reseau a surveiller ("auto" pour interface active)

settings-modules-netstat-format = Format d'affichage
    .description = Chaine de format avec placeholders: {"{{ down_kib }}"}, {"{{ down_mib }}"}, {"{{ down_gib }}"}, {"{{ down_auto }}"}, {"{{ up_kib }}"}, {"{{ up_mib }}"}, {"{{ up_gib }}"}, {"{{ up_auto }}"}, {"{{ interface }}"}

settings-modules-netstat-icon-name = Nom de l'icone
    .description = Nom icone symbolique

settings-modules-netstat-border-show = Afficher la bordure
    .description = Afficher une bordure autour du bouton

settings-modules-netstat-border-color = Couleur de bordure
    .description = Valeur de couleur de bordure

settings-modules-netstat-icon-show = Afficher l'icone
    .description = Afficher l'icone du module

settings-modules-netstat-icon-color = Couleur de l'icone
    .description = Couleur de premier plan de l'icone

settings-modules-netstat-icon-bg-color = Arriere-plan de l'icone
    .description = Couleur d'arriere-plan du conteneur d'icone

settings-modules-netstat-label-show = Afficher le libellé
    .description = Afficher le libellé texte

settings-modules-netstat-label-color = Couleur du libellé
    .description = Couleur du texte du libellé

settings-modules-netstat-label-max-length = Longueur max du libellé
    .description = Nombre maximal de caracteres avant troncature

settings-modules-netstat-button-bg-color = Arriere-plan du bouton
    .description = Couleur d'arriere-plan du bouton

settings-modules-netstat-left-click = Clic gauche
    .description = Commande shell au clic gauche

settings-modules-netstat-right-click = Clic droit
    .description = Commande shell au clic droit

settings-modules-netstat-middle-click = Clic milieu
    .description = Commande shell au clic milieu

settings-modules-netstat-scroll-up = Defilement vers le haut
    .description = Commande shell au defilement vers le haut

settings-modules-netstat-scroll-down = Defilement vers le bas
    .description = Commande shell au defilement vers le bas
