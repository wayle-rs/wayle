### Wayle Configuration - Aurora Module

## Aurora Module Configuration

settings-modules-aurora-location = Location
    .description = Name of the location for the aurora forecast (e.g. "Oslo, NO")

settings-modules-aurora-format = Format
    .description = Template for displaying the forecast (e.g. "{{percentage}}% {{type}}")

settings-modules-aurora-time-format = Time Format
    .description = Format for time stamps in the forecast (e.g. "%H:%M")

settings-modules-aurora-refresh-interval-seconds = Refresh Interval (seconds)
    .description = How often to fetch new Aurora data (in seconds)

settings-modules-aurora-icon-name = Icon Name
    .description = Icon identifier for the Aurora module button

settings-modules-aurora-border-show = Show Border
    .description = Display a border around the Aurora button

settings-modules-aurora-border-color = Border Color
    .description = Color token for the button border

settings-modules-aurora-icon-show = Show Icon
    .description = Display the module icon in the button

settings-modules-aurora-icon-color = Icon Color
    .description = Foreground color for the icon

settings-modules-aurora-icon-bg-color = Icon Background
    .description = Background color behind the icon

settings-modules-aurora-label-show = Show Label
    .description = Display textual label next to the icon

settings-modules-aurora-label-color = Label Color
    .description = Text color for the label

settings-modules-aurora-label-max-length = Label Max Length
    .description = Maximum characters before truncating the label

settings-modules-aurora-button-bg-color = Button Background
    .description = Background color of the Aurora button

settings-modules-aurora-left-click = Left Click
    .description = Action performed on left click

settings-modules-aurora-right-click = Right Click
    .description = Action performed on right click

settings-modules-aurora-middle-click = Middle Click
    .description = Action performed on middle click

settings-modules-aurora-scroll-up = Scroll Up
    .description = Action performed on scroll up

settings-modules-aurora-scroll-down = Scroll Down
    .description = Action performed on scroll down
