### Configuration Wayle - Module Stockage

## Configuration du module Stockage

settings-modules-storage-poll-interval-ms = Intervalle d'interrogation
    .description = Intervalle d'interrogation en millisecondes

settings-modules-storage-mount-point = Point de montage
    .description = Point de montage à surveiller (ex. : « / », « /home »)

settings-modules-storage-format = Format d'affichage
    .description = Chaîne de format avec espaces réservés : {"{{ percent }}"}, {"{{ used_tib }}"}, {"{{ used_gib }}"}, {"{{ used_mib }}"}, {"{{ used_auto }}"}, {"{{ total_tib }}"}, {"{{ total_gib }}"}, {"{{ total_mib }}"}, {"{{ total_auto }}"}, {"{{ free_tib }}"}, {"{{ free_gib }}"}, {"{{ free_mib }}"}, {"{{ free_auto }}"}, {"{{ filesystem }}"}

settings-modules-storage-icon-name = Nom de l'icône
    .description = Nom d'icône symbolique

settings-modules-storage-border-show = Afficher la bordure
    .description = Afficher une bordure autour du bouton

settings-modules-storage-border-color = Couleur de la bordure
    .description = Jeton de couleur de la bordure

settings-modules-storage-icon-show = Afficher l'icône
    .description = Afficher l'icône du module

settings-modules-storage-icon-color = Couleur de l'icône
    .description = Couleur de premier plan de l'icône

settings-modules-storage-icon-bg-color = Arrière-plan de l'icône
    .description = Couleur d'arrière-plan du conteneur d'icône

settings-modules-storage-label-show = Afficher le libellé
    .description = Afficher le libellé textuel

settings-modules-storage-label-color = Couleur du libellé
    .description = Couleur du texte du libellé

settings-modules-storage-label-max-length = Longueur max. du libellé
    .description = Nombre maximal de caractères avant troncature

settings-modules-storage-button-bg-color = Arrière-plan du bouton
    .description = Couleur d'arrière-plan du bouton

settings-modules-storage-left-click = Clic gauche
    .description = Commande à exécuter au clic gauche

settings-modules-storage-right-click = Clic droit
    .description = Commande à exécuter au clic droit

settings-modules-storage-middle-click = Clic central
    .description = Commande à exécuter au clic central

settings-modules-storage-scroll-up = Défilement vers le haut
    .description = Commande à exécuter au défilement vers le haut

settings-modules-storage-scroll-down = Défilement vers le bas
    .description = Commande à exécuter au défilement vers le bas

settings-modules-storage-thresholds = Seuils
    .description = Seuils de couleur qui changent selon le niveau de valeur
