### Configuration Wayle - Module Bluetooth

## Configuration du module Bluetooth

settings-modules-bluetooth-disabled-icon = Icône désactivée
    .description = Icône lorsque le Bluetooth est désactivé ou indisponible

settings-modules-bluetooth-disconnected-icon = Icône déconnectée
    .description = Icône lorsque le Bluetooth est activé mais aucun appareil connecté

settings-modules-bluetooth-connected-icon = Icône connectée
    .description = Icône lorsque des appareils sont connectés

settings-modules-bluetooth-searching-icon = Icône de recherche
    .description = Icône lors de la recherche d'appareils

settings-modules-bluetooth-border-show = Afficher la bordure
    .description = Afficher une bordure autour du bouton

settings-modules-bluetooth-border-color = Couleur de la bordure
    .description = Jeton de couleur de la bordure

settings-modules-bluetooth-icon-show = Afficher l'icône
    .description = Afficher l'icône du module

settings-modules-bluetooth-icon-color = Couleur de l'icône
    .description = Couleur de premier plan de l'icône

settings-modules-bluetooth-icon-bg-color = Arrière-plan de l'icône
    .description = Couleur d'arrière-plan du conteneur d'icône

settings-modules-bluetooth-label-show = Afficher le libellé
    .description = Afficher le libellé de connexion

settings-modules-bluetooth-label-color = Couleur du libellé
    .description = Couleur du texte du libellé

settings-modules-bluetooth-label-max-length = Longueur max. du libellé
    .description = Nombre maximal de caractères avant troncature

settings-modules-bluetooth-button-bg-color = Arrière-plan du bouton
    .description = Couleur d'arrière-plan du bouton

settings-modules-bluetooth-right-click = Clic droit
    .description = Commande à exécuter au clic droit

settings-modules-bluetooth-middle-click = Clic central
    .description = Commande à exécuter au clic central

settings-modules-bluetooth-scroll-up = Défilement vers le haut
    .description = Commande à exécuter au défilement vers le haut

settings-modules-bluetooth-scroll-down = Défilement vers le bas
    .description = Commande à exécuter au défilement vers le bas

settings-modules-bluetooth-left-click = Clic gauche
    .description = Action au clic gauche
