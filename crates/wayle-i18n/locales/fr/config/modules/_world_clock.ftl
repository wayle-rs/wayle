### Configuration Wayle - Module Horloge mondiale

## Configuration du module Horloge mondiale

settings-modules-world-clock-format = Format
    .description = Chaîne de format avec blocs de fuseau horaire intégrés en syntaxe {"{"}fuseau_horaire strftime{"}"}

settings-modules-world-clock-icon-name = Nom de l'icône
    .description = Nom d'icône symbolique

settings-modules-world-clock-border-show = Afficher la bordure
    .description = Afficher une bordure autour du bouton

settings-modules-world-clock-border-color = Couleur de la bordure
    .description = Jeton de couleur de la bordure

settings-modules-world-clock-icon-show = Afficher l'icône
    .description = Afficher l'icône du module

settings-modules-world-clock-icon-color = Couleur de l'icône
    .description = Couleur de premier plan de l'icône

settings-modules-world-clock-icon-bg-color = Arrière-plan de l'icône
    .description = Couleur d'arrière-plan du conteneur d'icône

settings-modules-world-clock-label-show = Afficher le libellé
    .description = Afficher le libellé textuel

settings-modules-world-clock-label-color = Couleur du libellé
    .description = Couleur du texte du libellé

settings-modules-world-clock-label-max-length = Longueur max. du libellé
    .description = Nombre maximal de caractères avant troncature

settings-modules-world-clock-button-bg-color = Arrière-plan du bouton
    .description = Couleur d'arrière-plan du bouton

settings-modules-world-clock-left-click = Clic gauche
    .description = Commande à exécuter au clic gauche

settings-modules-world-clock-right-click = Clic droit
    .description = Commande à exécuter au clic droit

settings-modules-world-clock-middle-click = Clic central
    .description = Commande à exécuter au clic central

settings-modules-world-clock-scroll-up = Défilement vers le haut
    .description = Commande à exécuter au défilement vers le haut

settings-modules-world-clock-scroll-down = Défilement vers le bas
    .description = Commande à exécuter au défilement vers le bas
