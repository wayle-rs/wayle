### Configuration Wayle - Module Statistiques réseau

## Configuration du module Statistiques réseau

settings-modules-netstat-poll-interval-ms = Intervalle d'interrogation
    .description = Intervalle d'interrogation en millisecondes

settings-modules-netstat-interface = Interface
    .description = Interface réseau à surveiller (« auto » pour l'interface active)

settings-modules-netstat-format = Format d'affichage
    .description = Chaîne de format avec espaces réservés : {"{{ down_kib }}"}, {"{{ down_mib }}"}, {"{{ down_gib }}"}, {"{{ down_auto }}"}, {"{{ up_kib }}"}, {"{{ up_mib }}"}, {"{{ up_gib }}"}, {"{{ up_auto }}"}, {"{{ interface }}"}

settings-modules-netstat-icon-name = Nom de l'icône
    .description = Nom d'icône symbolique

settings-modules-netstat-border-show = Afficher la bordure
    .description = Afficher une bordure autour du bouton

settings-modules-netstat-border-color = Couleur de la bordure
    .description = Jeton de couleur de la bordure

settings-modules-netstat-icon-show = Afficher l'icône
    .description = Afficher l'icône du module

settings-modules-netstat-icon-color = Couleur de l'icône
    .description = Couleur de premier plan de l'icône

settings-modules-netstat-icon-bg-color = Arrière-plan de l'icône
    .description = Couleur d'arrière-plan du conteneur d'icône

settings-modules-netstat-label-show = Afficher le libellé
    .description = Afficher le libellé textuel

settings-modules-netstat-label-color = Couleur du libellé
    .description = Couleur du texte du libellé

settings-modules-netstat-label-max-length = Longueur max. du libellé
    .description = Nombre maximal de caractères avant troncature

settings-modules-netstat-button-bg-color = Arrière-plan du bouton
    .description = Couleur d'arrière-plan du bouton

settings-modules-netstat-left-click = Clic gauche
    .description = Commande à exécuter au clic gauche

settings-modules-netstat-right-click = Clic droit
    .description = Commande à exécuter au clic droit

settings-modules-netstat-middle-click = Clic central
    .description = Commande à exécuter au clic central

settings-modules-netstat-scroll-up = Défilement vers le haut
    .description = Commande à exécuter au défilement vers le haut

settings-modules-netstat-scroll-down = Défilement vers le bas
    .description = Commande à exécuter au défilement vers le bas
