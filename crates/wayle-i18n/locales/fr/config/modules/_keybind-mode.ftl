### Configuration Wayle - Module Mode de raccourcis

## Configuration du module Mode de raccourcis

settings-modules-keybind-mode-format = Format du libellé
    .description = Chaîne de format avec espaces réservés : {"{{ mode }}"}

settings-modules-keybind-mode-icon-name = Nom de l'icône
    .description = Nom d'icône symbolique

settings-modules-keybind-mode-auto-hide = Masquage automatique
    .description = Masquer le module lorsqu'aucun mode n'est actif

settings-modules-keybind-mode-border-show = Afficher la bordure
    .description = Afficher une bordure autour du bouton

settings-modules-keybind-mode-border-color = Couleur de la bordure
    .description = Jeton de couleur de la bordure

settings-modules-keybind-mode-icon-show = Afficher l'icône
    .description = Afficher l'icône du module

settings-modules-keybind-mode-icon-color = Couleur de l'icône
    .description = Couleur de premier plan de l'icône

settings-modules-keybind-mode-icon-bg-color = Arrière-plan de l'icône
    .description = Couleur d'arrière-plan du conteneur d'icône

settings-modules-keybind-mode-label-show = Afficher le libellé
    .description = Afficher le libellé du mode

settings-modules-keybind-mode-label-color = Couleur du libellé
    .description = Couleur du texte du libellé

settings-modules-keybind-mode-label-max-length = Longueur max. du libellé
    .description = Nombre maximal de caractères avant troncature (0 pour désactiver)

settings-modules-keybind-mode-button-bg-color = Arrière-plan du bouton
    .description = Couleur d'arrière-plan du bouton

settings-modules-keybind-mode-left-click = Clic gauche
    .description = Commande à exécuter au clic gauche

settings-modules-keybind-mode-right-click = Clic droit
    .description = Commande à exécuter au clic droit

settings-modules-keybind-mode-middle-click = Clic central
    .description = Commande à exécuter au clic central

settings-modules-keybind-mode-scroll-up = Défilement vers le haut
    .description = Commande à exécuter au défilement vers le haut

settings-modules-keybind-mode-scroll-down = Défilement vers le bas
    .description = Commande à exécuter au défilement vers le bas
