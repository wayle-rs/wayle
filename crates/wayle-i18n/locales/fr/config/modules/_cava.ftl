### Configuration Wayle - Module Cava

## Traitement audio

settings-modules-cava-bars = Nombre de barres
    .description = Nombre de barres de fréquence

settings-modules-cava-framerate = Fréquence d'images
    .description = Taux de rafraîchissement de la visualisation en images par seconde

settings-modules-cava-stereo = Stéréo
    .description = Répartir les barres entre les canaux audio gauche et droit

settings-modules-cava-noise-reduction = Réduction du bruit
    .description = Intensité du filtre de réduction du bruit (0.0 rapide/bruité à 1.0 lent/lissé)

settings-modules-cava-monstercat = Lissage Monstercat
    .description = Atténuation progressive entre barres adjacentes (0.0 = désactivé)

settings-modules-cava-waves = Lissage par ondes
    .description = Nombre de lissages par ondes (0 = désactivé)

settings-modules-cava-low-cutoff = Fréquence basse
    .description = Fréquence de coupure basse en Hz

settings-modules-cava-high-cutoff = Fréquence haute
    .description = Fréquence de coupure haute en Hz

settings-modules-cava-input = Méthode d'entrée
    .description = Moteur de capture audio

settings-modules-cava-source = Source
    .description = Identifiant de la source audio (utiliser « auto » pour la sélection automatique)

## Visualisation

settings-modules-cava-style = Style
    .description = Style de rendu de la visualisation (barres, onde ou crêtes)

settings-modules-cava-direction = Direction
    .description = Direction de croissance des barres par rapport au bord de la barre

settings-modules-cava-color = Couleur
    .description = Couleur de la visualisation

settings-modules-cava-bar-width = Largeur des barres
    .description = Largeur de chaque barre de fréquence en pixels

settings-modules-cava-bar-gap = Écart entre barres
    .description = Espace entre les barres de fréquence en pixels

## Conteneur

settings-modules-cava-internal-padding = Marge intérieure
    .description = Marge intérieure aux extrémités du visualiseur en rem

settings-modules-cava-button-bg-color = Couleur d'arrière-plan
    .description = Couleur d'arrière-plan du module

settings-modules-cava-border-show = Afficher la bordure
    .description = Afficher une bordure autour du visualiseur

settings-modules-cava-border-color = Couleur de la bordure
    .description = Jeton de couleur de la bordure

settings-modules-cava-left-click = Clic gauche
    .description = Action au clic gauche

settings-modules-cava-right-click = Clic droit
    .description = Action au clic droit

settings-modules-cava-middle-click = Clic central
    .description = Action au clic central

settings-modules-cava-scroll-up = Défilement vers le haut
    .description = Action au défilement vers le haut

settings-modules-cava-scroll-down = Défilement vers le bas
    .description = Action au défilement vers le bas


## Variantes de CavaStyle
enum-cava-style-bars = Barres
enum-cava-style-wave = Onde
enum-cava-style-peaks = Crêtes

## Variantes de CavaDirection
enum-cava-direction-normal = Normal
enum-cava-direction-reverse = Inversé
enum-cava-direction-mirror = Miroir
