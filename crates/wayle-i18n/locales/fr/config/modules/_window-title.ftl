### Configuration Wayle - Module Titre de fenêtre

## Configuration du module Titre de fenêtre

settings-modules-window-title-format = Format du libellé
    .description = Chaîne de format avec espaces réservés : {"{{ title }}"}, {"{{ app }}"}

settings-modules-window-title-icon-name = Icône de repli
    .description = Icône lorsqu'aucune correspondance n'est trouvée

settings-modules-window-title-icon-mappings = Correspondances d'icônes
    .description = Motifs glob vers noms d'icônes (préfixer avec title: pour la correspondance par titre)

settings-modules-window-title-border-show = Afficher la bordure
    .description = Afficher une bordure autour du bouton

settings-modules-window-title-border-color = Couleur de la bordure
    .description = Jeton de couleur de la bordure

settings-modules-window-title-icon-show = Afficher l'icône
    .description = Afficher l'icône du module

settings-modules-window-title-icon-color = Couleur de l'icône
    .description = Couleur de premier plan de l'icône

settings-modules-window-title-icon-bg-color = Arrière-plan de l'icône
    .description = Couleur d'arrière-plan du conteneur d'icône

settings-modules-window-title-label-show = Afficher le libellé
    .description = Afficher le libellé du titre de fenêtre

settings-modules-window-title-label-color = Couleur du libellé
    .description = Couleur du texte du libellé

settings-modules-window-title-label-max-length = Longueur max. du libellé
    .description = Nombre maximal de caractères avant troncature (0 pour désactiver)

settings-modules-window-title-button-bg-color = Arrière-plan du bouton
    .description = Couleur d'arrière-plan du bouton

settings-modules-window-title-left-click = Clic gauche
    .description = Commande à exécuter au clic gauche

settings-modules-window-title-right-click = Clic droit
    .description = Commande à exécuter au clic droit

settings-modules-window-title-middle-click = Clic central
    .description = Commande à exécuter au clic central

settings-modules-window-title-scroll-up = Défilement vers le haut
    .description = Commande à exécuter au défilement vers le haut

settings-modules-window-title-scroll-down = Défilement vers le bas
    .description = Commande à exécuter au défilement vers le bas
