### Configuration Wayle - Module Mémoire vive

## Configuration du module Mémoire vive

settings-modules-ram-poll-interval-ms = Intervalle d'interrogation
    .description = Intervalle d'interrogation en millisecondes

settings-modules-ram-format = Format d'affichage
    .description = Chaîne de format avec espaces réservés : {"{{ percent }}"}, {"{{ used_gib }}"}, {"{{ total_gib }}"}, {"{{ available_gib }}"}, {"{{ swap_percent }}"}, {"{{ swap_used_gib }}"}, {"{{ swap_total_gib }}"}

settings-modules-ram-icon-name = Nom de l'icône
    .description = Nom d'icône symbolique

settings-modules-ram-border-show = Afficher la bordure
    .description = Afficher une bordure autour du bouton

settings-modules-ram-border-color = Couleur de la bordure
    .description = Jeton de couleur de la bordure

settings-modules-ram-icon-show = Afficher l'icône
    .description = Afficher l'icône du module

settings-modules-ram-icon-color = Couleur de l'icône
    .description = Couleur de premier plan de l'icône

settings-modules-ram-icon-bg-color = Arrière-plan de l'icône
    .description = Couleur d'arrière-plan du conteneur d'icône

settings-modules-ram-label-show = Afficher le libellé
    .description = Afficher le libellé textuel

settings-modules-ram-label-color = Couleur du libellé
    .description = Couleur du texte du libellé

settings-modules-ram-label-max-length = Longueur max. du libellé
    .description = Nombre maximal de caractères avant troncature

settings-modules-ram-button-bg-color = Arrière-plan du bouton
    .description = Couleur d'arrière-plan du bouton

settings-modules-ram-left-click = Clic gauche
    .description = Commande à exécuter au clic gauche

settings-modules-ram-right-click = Clic droit
    .description = Commande à exécuter au clic droit

settings-modules-ram-middle-click = Clic central
    .description = Commande à exécuter au clic central

settings-modules-ram-scroll-up = Défilement vers le haut
    .description = Commande à exécuter au défilement vers le haut

settings-modules-ram-scroll-down = Défilement vers le bas
    .description = Commande à exécuter au défilement vers le bas

settings-modules-ram-thresholds = Seuils
    .description = Seuils de couleur qui changent selon le niveau de valeur
