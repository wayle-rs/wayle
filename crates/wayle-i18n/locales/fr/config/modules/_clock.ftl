### Configuration Wayle - Module Horloge

## Configuration du module Horloge

settings-modules-clock-format = Format de l'heure
    .description = Format d'affichage de l'heure en syntaxe strftime

settings-modules-clock-icon-name = Nom de l'icône
    .description = Nom d'icône symbolique

settings-modules-clock-border-show = Afficher la bordure
    .description = Afficher une bordure autour du bouton

settings-modules-clock-border-color = Couleur de la bordure
    .description = Jeton de couleur de la bordure

settings-modules-clock-icon-show = Afficher l'icône
    .description = Afficher l'icône du module

settings-modules-clock-icon-color = Couleur de l'icône
    .description = Couleur de premier plan de l'icône

settings-modules-clock-icon-bg-color = Arrière-plan de l'icône
    .description = Couleur d'arrière-plan du conteneur d'icône

settings-modules-clock-label-show = Afficher le libellé
    .description = Afficher le libellé textuel

settings-modules-clock-label-color = Couleur du libellé
    .description = Couleur du texte du libellé

settings-modules-clock-label-max-length = Longueur max. du libellé
    .description = Nombre maximal de caractères avant troncature

settings-modules-clock-button-bg-color = Arrière-plan du bouton
    .description = Couleur d'arrière-plan du bouton

settings-modules-clock-left-click = Clic gauche
    .description = Commande à exécuter au clic gauche

settings-modules-clock-right-click = Clic droit
    .description = Commande à exécuter au clic droit

settings-modules-clock-middle-click = Clic central
    .description = Commande à exécuter au clic central

settings-modules-clock-scroll-up = Défilement vers le haut
    .description = Commande à exécuter au défilement vers le haut

settings-modules-clock-scroll-down = Défilement vers le bas
    .description = Commande à exécuter au défilement vers le bas

settings-modules-clock-dropdown-show-seconds = Afficher les secondes
    .description = Afficher les secondes dans l'horloge du calendrier déroulant
