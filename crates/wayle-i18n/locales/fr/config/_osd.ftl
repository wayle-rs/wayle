
settings-osd-enabled = Activé
    .description = Afficher des surcouches à l'écran pour le volume, la luminosité, etc.

settings-osd-position = Position
    .description = Où l'OSD apparaît à l'écran (par ex. haut-centre, bas-droite)

settings-osd-duration = Durée
    .description = Durée pendant laquelle l'OSD reste visible avant de se fermer automatiquement (ms)

settings-osd-monitor = Moniteur
    .description = Quel moniteur affiche l'OSD : « primary » ou un connecteur comme « DP-1 »

settings-osd-margin = Marge
    .description = Distance entre le bord de l'écran et l'OSD

settings-osd-border = Bordure
    .description = Dessiner une bordure autour de la surcouche OSD


