### Configuration Wayle - Paramètres de la barre

## Configuration de la barre - Paramètres généraux

settings-bar-layout = Disposition
    .description = Dispositions de barre par moniteur définissant l'agencement des modules

settings-bar-scale = Échelle
    .description = Multiplicateur d'échelle de la barre pour l'espacement, les arrondis et autres éléments

settings-bar-inset-edge = Retrait du bord
    .description = Espace entre la barre et le bord de l'écran auquel elle est attachée

settings-bar-inset-ends = Retrait des extrémités
    .description = Espace aux extrémités de la barre (gauche/droite en horizontal, haut/bas en vertical)

settings-bar-padding = Marge intérieure
    .description = Espacement interne le long de l'épaisseur de la barre

settings-bar-padding-ends = Marge intérieure des extrémités
    .description = Espacement interne aux extrémités de la barre

settings-bar-module-gap = Écart entre modules
    .description = Espace entre les modules et les groupes sur la barre

settings-bar-location = Position
    .description = Position de la barre sur le bord de l'écran (haut, bas, gauche, droite)

settings-bar-bg = Arrière-plan
    .description = Couleur d'arrière-plan de la barre

settings-bar-background-opacity = Opacité de l'arrière-plan
    .description = Transparence de l'arrière-plan de la barre (0-100 %)

settings-bar-border-location = Position de la bordure
    .description = Emplacement de la bordure de la barre

settings-bar-border-width = Épaisseur de la bordure
    .description = Épaisseur de la bordure en pixels

settings-bar-border-color = Couleur de la bordure
    .description = Couleur de la bordure de la barre

settings-bar-rounding = Arrondis
    .description = Niveau d'arrondi des coins de la barre

settings-bar-shadow-enabled = Ombre
    .description = Activer l'ombre portée sur la barre

## Configuration de la barre - Paramètres des boutons/modules

settings-bar-button-opacity = Opacité des boutons
    .description = Transparence des boutons de la barre (0-100 %)

settings-bar-button-bg-opacity = Opacité de l'arrière-plan des boutons
    .description = Transparence de la couleur d'arrière-plan des boutons de la barre (0-100 %)

settings-bar-button-icon-size = Taille de l'icône du bouton
    .description = Multiplicateur de taille pour les icônes de bouton

settings-bar-button-icon-padding = Marge intérieure de l'icône du bouton
    .description = Marge intérieure autour des icônes de bouton. S'applique uniquement aux variantes block-prefix et icon-square.

settings-bar-button-label-size = Taille du libellé du bouton
    .description = Multiplicateur de taille pour le texte des boutons

settings-bar-button-label-weight = Graisse du libellé du bouton
    .description = Graisse de la police pour les libellés des boutons

settings-bar-button-label-padding = Marge intérieure du libellé du bouton
    .description = Marge intérieure autour des libellés des boutons

settings-bar-button-gap = Écart du bouton
    .description = Espace entre l'icône et le libellé dans les boutons

settings-bar-button-icon-position = Position de l'icône du bouton
    .description = Placement de l'icône par rapport au libellé (début ou fin)

settings-bar-button-border-location = Position de la bordure du bouton
    .description = Emplacement de la bordure des boutons de la barre

settings-bar-button-border-width = Épaisseur de la bordure du bouton
    .description = Épaisseur de la bordure des boutons de la barre en pixels

## Configuration de la barre - Paramètres des groupes de boutons

settings-bar-button-group-border-location = Position de la bordure du groupe
    .description = Emplacement de la bordure des groupes de boutons

settings-bar-button-group-border-width = Épaisseur de la bordure du groupe
    .description = Épaisseur de la bordure des groupes de boutons en pixels

settings-bar-button-group-padding = Marge intérieure du groupe
    .description = Marge intérieure au sein des groupes de boutons

settings-bar-group-module-gap = Écart entre modules du groupe
    .description = Espace entre les modules au sein d'un groupe

settings-bar-button-group-background = Arrière-plan du groupe
    .description = Couleur d'arrière-plan des groupes de boutons

settings-bar-button-group-opacity = Opacité du groupe
    .description = Transparence des groupes de boutons (0-100 %)

settings-bar-button-group-border-color = Couleur de la bordure du groupe
    .description = Couleur de la bordure des groupes de boutons

## Configuration de la barre - Paramètres du menu déroulant

settings-bar-dropdown-size = Taille du menu déroulant
    .description = Multiplicateur de taille pour les panneaux déroulants

settings-bar-dropdown-shadow = Ombre du menu déroulant
    .description = Activer l'ombre portée sur les menus déroulants

settings-bar-dropdown-opacity = Opacité du menu déroulant
    .description = Transparence des panneaux déroulants (0-100 %)

settings-bar-dropdown-autohide = Masquage automatique du menu déroulant
    .description = Fermer le menu déroulant lors d'un clic à l'extérieur

settings-bar-dropdown-freeze-label = Figer le libellé
    .description = Empêcher la mise à jour du libellé du bouton de la barre lorsque son menu déroulant est ouvert

settings-bar-shadow = Ombre
    .description = Activer l'ombre portée

settings-bar-button-variant = Variante du bouton
    .description = Style visuel des boutons de la barre

settings-bar-button-rounding = Arrondis du bouton
    .description = Arrondi des coins des boutons de la barre

settings-bar-button-group-module-gap = Écart entre modules du groupe
    .description = Espace entre les modules au sein d'un groupe

settings-bar-button-group-rounding = Arrondis du groupe
    .description = Arrondi des coins des groupes de boutons

