### Configuration Wayle - Paramètres de la barre

## Configuration de la barre - Paramètres de la barre

settings-bar-layout = Disposition
    .description = Dispositions de barre par écran définissant l'agencement des modules

settings-bar-scale = Échelle
    .description = Multiplicateur d'échelle propre à la barre pour les espacements, rayons et autres éléments

settings-bar-inset-edge = Marge au bord
    .description = Écart entre la barre et le bord d'écran auquel elle est attachée

settings-bar-inset-ends = Marge aux extrémités
    .description = Écart aux extrémités de la barre (gauche/droite en horizontal, haut/bas en vertical)

settings-bar-padding = Remplissage
    .description = Espacement interne sur l'épaisseur de la barre

settings-bar-padding-ends = Remplissage aux extrémités
    .description = Espacement interne aux extrémités de la barre

settings-bar-module-gap = Écart entre modules
    .description = Écart entre les modules et groupes sur la barre

settings-bar-location = Emplacement
    .description = Position de la barre sur le bord d'écran (haut, bas, gauche, droite)

settings-bar-bg = Arrière-plan
    .description = Couleur d'arrière-plan de la barre

settings-bar-background-opacity = Opacité de l'arrière-plan
    .description = Transparence de l'arrière-plan de la barre (0-100 %)

settings-bar-border-location = Position de la bordure
    .description = Positionnement de la bordure de la barre

settings-bar-border-width = Largeur de bordure
    .description = Épaisseur de la bordure en pixels

settings-bar-border-color = Couleur de bordure
    .description = Couleur de la bordure de la barre

settings-bar-rounding = Arrondi
    .description = Niveau d'arrondi des coins de la barre

settings-bar-shadow-enabled = Ombre
    .description = Activer l'ombre portée sur la barre

## Configuration de la barre - Paramètres des boutons/modules

settings-bar-button-opacity = Opacité des boutons
    .description = Transparence des boutons de la barre (0-100 %)

settings-bar-button-bg-opacity = Opacité de l'arrière-plan des boutons
    .description = Transparence de la couleur d'arrière-plan des boutons de la barre (0-100 %)

settings-bar-button-icon-size = Taille des icônes des boutons
    .description = Multiplicateur de taille pour les icônes des boutons

settings-bar-button-icon-padding = Remplissage des icônes des boutons
    .description = Espacement autour des icônes des boutons. S'applique uniquement aux variantes block-prefix et icon-square.

settings-bar-button-label-size = Taille du libellé des boutons
    .description = Multiplicateur de taille pour le texte des boutons

settings-bar-button-label-weight = Épaisseur du libellé des boutons
    .description = Épaisseur de police pour les libellés des boutons

settings-bar-button-label-padding = Remplissage du libellé des boutons
    .description = Espacement autour des libellés des boutons

settings-bar-button-gap = Écart du bouton
    .description = Écart entre l'icône et le libellé dans les boutons

settings-bar-button-icon-position = Position de l'icône des boutons
    .description = Position de l'icône par rapport au libellé (début ou fin)

settings-bar-button-border-location = Position de la bordure des boutons
    .description = Positionnement de la bordure des boutons de la barre

settings-bar-button-border-width = Largeur de bordure des boutons
    .description = Épaisseur de la bordure des boutons de la barre en pixels

## Configuration de la barre - Paramètres des groupes de boutons

settings-bar-button-group-border-location = Position de la bordure des groupes
    .description = Positionnement de la bordure des groupes de boutons

settings-bar-button-group-border-width = Largeur de bordure des groupes
    .description = Épaisseur de la bordure des groupes de boutons en pixels

settings-bar-button-group-padding = Remplissage des groupes
    .description = Espacement interne des groupes de boutons

settings-bar-group-module-gap = Écart entre modules du groupe
    .description = Écart entre les modules à l'intérieur d'un groupe

settings-bar-button-group-background = Arrière-plan des groupes
    .description = Couleur d'arrière-plan des groupes de boutons

settings-bar-button-group-opacity = Opacité des groupes
    .description = Transparence des groupes de boutons (0-100 %)

settings-bar-button-group-border-color = Couleur de bordure des groupes
    .description = Couleur de la bordure des groupes de boutons

## Configuration de la barre - Paramètres des menus déroulants

settings-bar-dropdown-size = Taille des menus déroulants
    .description = Multiplicateur de taille pour les panneaux déroulants

settings-bar-dropdown-shadow = Ombre des menus déroulants
    .description = Activer l'ombre portée sur les menus déroulants

settings-bar-dropdown-opacity = Opacité des menus déroulants
    .description = Transparence des panneaux déroulants (0-100 %)

settings-bar-dropdown-autohide = Masquage automatique des menus déroulants
    .description = Fermer le menu déroulant lors d'un clic à l'extérieur

settings-bar-dropdown-freeze-label = Geler le libellé
    .description = Empêcher la mise à jour du libellé du bouton de barre tant que son menu déroulant est ouvert
